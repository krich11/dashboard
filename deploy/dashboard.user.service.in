[Unit]
Description=Datacenter Dashboard API
Documentation=file://@INSTALL_DIR@/README.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=@INSTALL_DIR@
EnvironmentFile=-@INSTALL_DIR@/.env
Environment=PYTHONPATH=@INSTALL_DIR@/backend
Environment=FRONTEND_STATIC_DIR=@INSTALL_DIR@/frontend/dist
ExecStart=@PYTHON@ -m uvicorn app.main:app --host @BIND_HOST@ --port @PORT@
Restart=on-failure
RestartSec=5
TimeoutStopSec=30

[Install]
WantedBy=default.target