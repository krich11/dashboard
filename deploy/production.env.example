# Copy to deploy/production.env and set your production target.
# deploy/production.env is gitignored.

# SSH target for remote deploy (required unless using --local)
PRODUCTION_SSH=krich@dashboard-host.example.com

# Paths on the production server
PRODUCTION_INSTALL_DIR=/opt/dashboard
PRODUCTION_SERVICE_USER=dashboard
PRODUCTION_PORT=8000

# Optional SSH options (e.g. -i ~/.ssh/id_ed25519)
# PRODUCTION_SSH_OPTS=-o StrictHostKeyChecking=accept-new