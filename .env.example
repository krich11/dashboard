MOCK_MODE=true
MOCK_SCENARIO=all_clear
DATABASE_URL=sqlite:///./data/dashboard.db
DASHBOARD_SECRET_KEY=change-me-in-production

# Optional: require X-API-Key header on API routes (leave unset for open/trusted-LAN mode)
# DASHBOARD_API_KEY=

# Status history retention (days) and per-device cap
# STATUS_HISTORY_RETENTION_DAYS=30
# STATUS_HISTORY_MAX_PER_DEVICE=5000

# Production: set MOCK_MODE=false, use openssl rand -hex 32 for DASHBOARD_SECRET_KEY
# CORS_ORIGINS=["https://dashboard.example.com"]
# FRONTEND_STATIC_DIR=/opt/dashboard/frontend/dist