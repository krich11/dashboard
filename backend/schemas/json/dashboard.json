{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://datacenter-dashboard.local/schemas/dashboard.json",
  "title": "DashboardExport",
  "type": "object",
  "required": ["export_version", "name", "layout", "widgets"],
  "properties": {
    "export_version": { "type": "string", "const": "1.0" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "layout": { "type": "object" },
    "widgets": {
      "type": "array",
      "items": { "$ref": "widget-instance.json" }
    }
  }
}